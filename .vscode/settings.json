{
    "eslint.workingDirectories": [
        {
            "mode": "auto"
        }
    ],
    "files.exclude": {
        "**/node_modules": true,
        "**/dist": true,
        "**/.turbo": true,
        "**/.next": true,
        "**/.cache": true
    },

    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.patterns": {
        "package.json": ".prettierrc, .gitignore, .npmrc, pnpm-lock.yaml, pnpm-workspace.yaml, tsconfig.json, turbo.json, tsup.config.ts",
        ".env": ".env.example, nginx.conf, nginx.old.conf",
        "README.md": "LICENSE.md",
        "app.json": "app.json, babel.config.js, eas.json, expo-env.d.ts, metro.config.js"
    },
    "postman.settings.dotenv-detection-notification-visibility": false
}
