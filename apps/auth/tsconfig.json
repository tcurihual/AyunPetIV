{
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "rootDir": "src",
        "outDir": "dist",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "allowSyntheticDefaultImports": true,
        "strict": true
    },
    "exclude": ["node_modules", "dist", "tsup.config.ts", "*.config.ts", "**/*.config.ts"],
    "include": ["src/**/*"]
}
