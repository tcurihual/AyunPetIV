{
    "extends": "expo/tsconfig.base",
    "compilerOptions": {
        "jsx": "react",
        "strict": true,
        "esModuleInterop": true,
        "paths": {
            "@/*": ["./*"],
            "@ui/*": ["./components/ui/*"],
            "@common/*": ["./components/common/*"],
            "@images/*": ["./assets/images/*"],
            "@fonts/*": ["./assets/fonts/*"],
            "@animations/*": ["./assets/animations/*"]
        }
    },
    "skipLibCheck": true,
    "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts", "app/(auth)/index.tsx", "app/(auth)/remembered-login.tsx", "app/(shelter)/index.tsx", "features/TryBiometricLogin.tsx"]
}
