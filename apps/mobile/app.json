{
    "expo": {
        "name": "ayunpet",
        "slug": "ayun-pet",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/images/image.png",
        "scheme": "myapp",
        "userInterfaceStyle": "light",
        "newArchEnabled": true,
        "ios": {
            "supportsTablet": true,
            "infoPlist": {
                "NSCameraUsageDescription": "La app necesita acceder a la cámara para tomar fotos.",
                "NSPhotoLibraryAddUsageDescription": "La app necesita guardar fotos en tu biblioteca.",
                "NSPhotoLibraryUsageDescription": "La app necesita acceder a tu biblioteca para leer fotos (al previsualizar/seleccionar)."
            }
        },
        "android": {
            "softwareKeyboardLayoutMode": "pan",
            "adaptiveIcon": {
                "foregroundImage": "./assets/images/image.png",
                "backgroundColor": "#ffffff"
            },
            "permissions": [
                "CAMERA",
                "READ_MEDIA_IMAGES",
                "READ_EXTERNAL_STORAGE",
                "POST_NOTIFICATIONS",
                "INTERNET",
                "ACCESS_NETWORK_STATE"
            ],
            "package": "com.aliwenn.ayunpet"
        },
        "web": {
            "bundler": "metro",
            "output": "static",
            "favicon": "./assets/images/favicon.png"
        },
        "plugins": [
            "expo-router",
            "expo-font",
            "expo-web-browser",
            ["expo-secure-store", { "configureAndroidBackup": true }],
            [
                "expo-notifications",
                {
                    "icon": "./assets/images/notification-icon.png",
                    "color": "#F9C80E",
                    "sounds": []
                }
            ],
            [
                "expo-build-properties",
                {
                    "android": {
                        "usesCleartextTraffic": true
                    }
                }
            ]
        ],
        "experiments": {
            "typedRoutes": true
        },
        "extra": {
            "router": {
                "disableSplashScreen": true
            },
            "eas": {
                "projectId": "eb7c9226-9e5c-4134-9698-9dec4436e685"
            }
        },
        "owner": "aliwenn"
    }
}
